# Для Docker (docker-compose up -d):
DATABASE_URL=postgresql://carmatch:carmatch@localhost:5433/carmatch
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS (через запятую для production, например Render frontend URL)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://carmatch-frontend.onrender.com

# Яндекс (Yandex Cloud): эмбеддинги + LLM для чата подбора авто — см. EMBEDDINGS.md
# При заданных YANDEX_FOLDER_ID и YANDEX_API_KEY чат использует YandexGPT вместо GigaChat.
YANDEX_FOLDER_ID=
YANDEX_API_KEY=

# GigaChat API (ключ авторизации из https://developers.sber.ru/studio/)
GIGACHAT_CREDENTIALS=
# При проблемах с SSL (например, локально): GIGACHAT_VERIFY_SSL_CERTS=false
